# Ejemplo de variables de entorno para Vercel
# Copiar este archivo a .env.local y llenar con tus valores reales

# Compac API Configuration (Opcional - puede venir de la app)
COMPAC_API_URL=https://api.compac.com/v1/
COMPAC_API_KEY=tu_api_key_aqui

# Google Cloud Configuration (Opcional - puede venir de la app)
GOOGLE_PROJECT_ID=tu-project-id
GOOGLE_CLIENT_EMAIL=maya-sync@tu-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nxxxx\n-----END PRIVATE KEY-----\n

# Verificación de Deploy
ENVIRONMENT=production
