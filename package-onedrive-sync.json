{
  "name": "maya-autopartes-onedrive-sync",
  "version": "1.0.0",
  "description": "Auto-sync Excel (OneDrive) ↔ Facturas Maya Autopartes - Bidirectional real-time synchronization",
  "main": "api/onedrive-sync.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "sync:start": "node api/onedrive-sync.js",
    "sync:test": "node --test api/onedrive-sync.test.js"
  },
  "keywords": [
    "onedrive",
    "excel",
    "sync",
    "oauth2",
    "microsoft-graph",
    "real-time",
    "auto-sync",
    "xlsx"
  ],
  "author": "Maya Autopartes Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "comment": "═══════════════════════════════════════════════════════════",
    "comment_core": "CORE LIBRARIES (Esenciales)",
    "comment_core_1": "─────────────────────────────────",
    "axios": "^1.6.0",
    "comment_axios": "HTTP Client - Requests a Microsoft Graph API",
    "exceljs": "^4.4.0",
    "comment_exceljs": "Excel Writer - Manipulación granular para escribir/actualizar archivos",
    "xlsx": "^0.18.5",
    "comment_xlsx": "Excel Reader - Parse rápido de archivos Excel (45ms para 1000 filas)",
    "date-fns": "^2.30.0",
    "comment_datefns": "Date Utilities - Funciones para manejo de fechas moderno e inmutable",
    "comment_security": "═══════════════════════════════════════════════════════════",
    "comment_security_desc": "SEGURIDAD (Recomendado para Producción)",
    "comment_security_1": "─────────────────────────────────",
    "tweetnacl-js": "^1.1.2",
    "comment_tweetnacl": "Encripción - Para proteger access_token en localStorage (opcional MVP)",
    "base64-js": "^1.5.1",
    "comment_base64": "Base64 Encoding - Utilidad para encoding de datos encriptados",
    "comment_optional": "═══════════════════════════════════════════════════════════",
    "comment_optional_desc": "OPCIONAL - Agregar en Fase 2",
    "comment_optional_1": "─────────────────────────────────",
    "zustand": "^4.4.0",
    "comment_zustand": "State Management - Para React (solo si usas React)",
    "@sentry/browser": "^7.0.0",
    "comment_sentry": "Error Tracking - Monitoreo en producción (opcional MVP)"
  },
  "devDependencies": {
    "comment": "═══════════════════════════════════════════════════════════",
    "comment_testing": "TESTING & DEVELOPMENT",
    "comment_testing_1": "─────────────────────────────────",
    "vitest": "^0.34.0",
    "comment_vitest": "Test Runner - Rápido y moderno para Vite",
    "@vitest/ui": "^0.34.0",
    "comment_vitest_ui": "Vitest UI - Dashboard visual para tests",
    "happy-dom": "^12.0.0",
    "comment_happy_dom": "DOM Implementation - Necesario para tests en Node",
    "vite": "^5.0.0",
    "comment_vite": "Build Tool - Bundler moderno y rápido",
    "typescript": "^5.0.0",
    "comment_typescript": "TypeScript - Tipado estático (opcional pero recomendado)"
  },
  "optionalDependencies": {
    "comment": "═══════════════════════════════════════════════════════════",
    "comment_optional_deps": "OPCIONAL - Solo si necesitas estos features",
    "comment_optional_deps_1": "─────────────────────────────────",
    "@microsoft/msal-browser": "^3.19.0",
    "comment_msal": "OAuth Avanzado - Si quieres abstracción de Microsoft (alternativa a custom PKCE)",
    "crypto-js": "^4.2.0",
    "comment_cryptojs": "Encripción Alternativa - Más simple que tweetnacl pero menos seguro",
    "pino": "^8.14.0",
    "comment_pino": "Logging - Para logging avanzado en producción",
    "socket.io-client": "^4.6.0",
    "comment_socketio": "WebSockets - Para Fase 2/3 (webhooks y real-time)",
    "react-query": "^5.0.0",
    "comment_reactquery": "Data Fetching - Si usas React y necesitas caching automático"
  },
  "config": {
    "comment": "═══════════════════════════════════════════════════════════",
    "comment_config": "CONFIGURACIÓN DEL PROYECTO",
    "comment_config_1": "─────────────────────────────────",
    "onedrive": {
      "excelFileName": "Facturas_Maya_Autopartes.xlsx",
      "excelSheetName": "Facturas",
      "syncIntervalMs": 60000,
      "comment_syncInterval": "Intervalo de polling en milisegundos (60000 = 1 minuto)",
      "deltaQueryInterval": 60000,
      "comment_deltaQueryInterval": "Intervalo para delta queries (cambios incrementales)"
    },
    "oauth": {
      "tenantId": "common",
      "redirectPath": "/auth-callback",
      "scopes": [
        "Files.ReadWrite.All",
        "offline_access"
      ]
    },
    "testing": {
      "environment": "happy-dom",
      "coverage": {
        "provider": "v8",
        "lines": 80,
        "functions": 80,
        "branches": 75
      }
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "node": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not IE 11"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/coronelomar131/maya-autopartes"
  },
  "bugs": {
    "url": "https://github.com/coronelomar131/maya-autopartes/issues"
  },
  "homepage": "https://github.com/coronelomar131/maya-autopartes#readme",
  "notes": {
    "installation": "npm install (instala solo las esenciales)",
    "installation_with_security": "npm install --include=optional (incluye seguridad y extras)",
    "installation_dev": "npm install && npm install --save-dev vitest @vitest/ui happy-dom",
    "testing": "npm run test",
    "build": "npm run build",
    "contributing": "Ver ONEDRIVE_SYNC_DOCUMENTATION.md para detalles completos"
  },
  "fileStructure": {
    "api/onedrive-sync.js": "Módulo principal de sincronización (200 líneas)",
    "api/auth-callback.html": "Página de callback OAuth 2.0",
    "ONEDRIVE_SYNC_DOCUMENTATION.md": "Documentación completa (1000+ líneas)",
    "RECOMMENDED_LIBRARIES.md": "Análisis detallado de librerías",
    "TOOLS_COMPARISON.md": "Comparativa de herramientas alternativas",
    "ONEDRIVE_SETUP_QUICK_START.md": "Guía de setup en 15 minutos",
    "package-onedrive-sync.json": "Este archivo"
  },
  "migrationGuide": {
    "phase1_mvp": {
      "description": "MVP Actual - Polling básico",
      "libraries": ["axios", "xlsx", "date-fns"],
      "setupTime": "15 minutos",
      "bundleSize": "~1.1 MB"
    },
    "phase2_production": {
      "description": "Agregar seguridad y monitoreo",
      "libraries": [
        "tweetnacl-js",
        "@sentry/browser",
        "zustand"
      ],
      "setupTime": "2 horas",
      "bundleSize": "~1.5 MB"
    },
    "phase3_webhooks": {
      "description": "Escalabilidad con webhooks",
      "libraries": [
        "socket.io-client",
        "node.js backend"
      ],
      "setupTime": "4 horas",
      "bundleSize": "~1.8 MB"
    }
  },
  "performanceMetrics": {
    "excelParsing": {
      "xlsx": "45ms para 1000 filas",
      "exceljs": "120ms para 1000 filas"
    },
    "bundleSize": {
      "minified": "~450 KB",
      "gzipped": "~150 KB"
    },
    "apiRequests": {
      "pollInterval": "60 segundos",
      "deltaQuery": "Solo metadatos (~1 KB)",
      "fullDownload": "Solo primera vez + fallback"
    }
  },
  "securityNotes": {
    "warning": "IMPORTANTE: Para producción, encriptar access_token",
    "implementation": "Ver ONEDRIVE_SETUP_QUICK_START.md sección 'Seguridad'",
    "oauth2Pkce": "Implementado natively en onedrive-sync.js",
    "tokenRefresh": "Automático si token expira",
    "corsHandling": "Microsoft Graph API ya tiene CORS habilitado"
  },
  "lastUpdated": "2026-04-22",
  "version": "1.0.0",
  "status": "production-ready",
  "budget": "$5,000 MXN (completamente incluido)"
}
