{
  "name": "maya-autopartes-backend",
  "version": "1.0.0",
  "description": "Backend API Core para Maya Autopartes - Gestión de Inventario",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --testTimeout=10000",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "type-check": "node -e \"console.log('No TypeScript in this project')\"",
    "build": "echo 'Building backend... (Node.js app - no build step required)' && exit 0",
    "verify": "npm run lint && npm run test && npm run build",
    "deploy": "vercel",
    "deploy:prod": "vercel --prod",
    "deploy:preview": "vercel --scope=maya-autopartes",
    "health-check": "curl http://localhost:5000/api/health",
    "health-check:prod": "curl https://maya-api.vercel.app/api/health"
  },
  "keywords": [
    "inventory",
    "sales",
    "supabase",
    "api"
  ],
  "author": "Maya Autopartes",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "@supabase/supabase-js": "^2.38.4",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.0",
    "axios": "^1.6.2",
    "compression": "^1.7.4",
    "uuid": "^9.0.1",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "redis": "^4.6.10",
    "lz-string": "^1.5.0",
    "socket.io": "^4.5.4",
    "http": "^0.0.1-security"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
