# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SECRET_KEY=your_supabase_service_key

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=your_jwt_secret_key_min_32_chars_long
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10

# ============================================================================
# REDIS CONFIGURATION (Optional for caching)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# API CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
API_PREFIX=/api/v1

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Google Drive API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Microsoft OneDrive / 365
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=your_microsoft_tenant_id

# MercadoLibre API
MERCADOLIBRE_CLIENT_ID=your_ml_client_id
MERCADOLIBRE_CLIENT_SECRET=your_ml_client_secret
MERCADOLIBRE_ACCESS_TOKEN=your_ml_access_token

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Maya Autopartes

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# DATABASE BACKUPS
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=30

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_GOOGLE_DRIVE=true
FEATURE_ONEDRIVE=true
FEATURE_MERCADOLIBRE=true
FEATURE_INVENTORY_SYNC=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# SECURITY
# ============================================================================
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MS=900000
SESSION_TIMEOUT_MS=3600000
CSRF_PROTECTION=true
HELMET_ENABLED=true
